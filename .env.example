# Required for real BigQuery runs
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
BIGQUERY_DATASET=bigquery-public-data.thelook_ecommerce
# Docker only: host-side path to the same service account key file, mounted read-only into
# the container as /app/gcp-key.json by docker-compose.yml. Ignored for native/non-Docker runs.
GCP_KEY_HOST_PATH=./secrets/key.json
# Required for real LLM runs. Leave USE_STUB_LLM=true for local smoke tests.
GEMINI_API_KEY=
GEMINI_MODEL_NAME=
GEMINI_FALLBACK_MODEL_NAME=

# Optional fallback providers
OPENROUTER_API_KEY=
OPENROUTER_MODEL_NAME=google/gemini-flash-1.5
OLLAMA_MODEL_NAME=llama3.1

# Safety budgets
MAX_BYTES_BILLED=200000000
MAX_ROWS_RETURNED=100
BQ_LOCATION=US

# Local prototype mode
USE_STUB_LLM=true
USE_MOCK_BQ=true
SQLITE_PATH=local_data/reports.sqlite3
LOG_PATH=logs/agent.jsonl
# Deep-dive debugging: log PII-masked prompt/response previews for every LLM call
LLM_TRACE=false

# Optional: LangSmith automatic tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=

# Local CLI auth. Quick-start demo token for demo_manager is configured in config/users.yaml.
RETAIL_INSIGHTS_AUTH_REQUIRED=true
RETAIL_INSIGHTS_USER_TOKEN=demo-token
# For production-like local runs prefer per-user env vars from config/users.yaml:
DEMO_MANAGER_TOKEN=
MANAGER_A_TOKEN=
MANAGER_B_TOKEN=


